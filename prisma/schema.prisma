// Prisma schema for GeKnee travel app
// Database: PostgreSQL via Supabase
// Used by: NextAuth.js v5 for user accounts

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // pooled (port 6543) — used by the app
  directUrl = env("DIRECT_DATABASE_URL") // direct (port 5432) — used by migrations
}

generator client {
  provider = "prisma-client-js"
}

// ── NextAuth required models ───────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?   // null for OAuth users; bcrypt hash for email/password
  username      String?   @unique // chosen display handle e.g. @travelguy — lowercase, no spaces
  lastSeen      DateTime? // updated on presence ping — used for online status

  accounts Account[]
  sessions Session[]
  trips    TripDraft[]
  tripFiles TripFile[]
  sentFriendRequests     Friendship[] @relation("SentRequests")
  receivedFriendRequests Friendship[] @relation("ReceivedRequests")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Trip drafts ───────────────────────────────────────────────────────────────

model TripDraft {
  id        String   @id @default(cuid())
  userId    String
  title     String
  location  String
  startDate String?
  endDate   String?
  nights    Int?
  style              String?  // JSON stringified preferences (from /plan/style)
  notes              String?
  itinerary          String?  // Full markdown itinerary text
  itineraryUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  files TripFile[]
}

// ── Trip File Vault ───────────────────────────────────────────────────────────

model TripFile {
  id        String   @id @default(cuid())
  tripId    String
  userId    String
  name      String   // original filename
  url       String   // Supabase Storage public URL
  storagePath String // path in bucket for deletion
  size      Int      // bytes
  tag       String   @default("other") // passport | booking | insurance | photo | other
  createdAt DateTime @default(now())

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip TripDraft @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// ── Friends ───────────────────────────────────────────────────────────────────

model Friendship {
  id       String @id @default(cuid())
  userId   String // who sent the request
  friendId String // who received it
  status   String @default("pending") // pending | accepted

  createdAt DateTime @default(now())

  user   User @relation("SentRequests",     fields: [userId],   references: [id], onDelete: Cascade)
  friend User @relation("ReceivedRequests", fields: [friendId], references: [id], onDelete: Cascade)

  @@unique([userId, friendId])
}
